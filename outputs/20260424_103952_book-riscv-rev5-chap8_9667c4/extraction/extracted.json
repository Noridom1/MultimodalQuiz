  "definitions": {
    "operating system": "A system that manages computer hardware and software resources and provides common services for computer programs.",
    "processes": "Instances of computer programs that are being executed.",
    "time-share": "A method of sharing computer resources among multiple users or processes by allocating time slots to each.",
    "multiplexing": "The process of switching a CPU from one process to another.",
    "xv6": "An operating system used in the example.",
    "system call": "A request made by a process to the operating system to perform a specific task.",
    "blocking": "A state where a process is waiting for an event or resource to become available.",
    "voluntary switches": "Process switches that occur when a process makes a blocking system call.",
    "involuntary switches": "Process switches that occur periodically to cope with long-running processes.",
    "context switches": "The process of switching from one process to another.",
    "hardware timer": "A component that generates periodic interrupts to drive context switches.",
    "interrupts": "Signals sent to the CPU to indicate an event that needs immediate attention.",
    "locking plan": "A strategy to prevent multiple CPUs from accessing shared resources simultaneously.",
    "multi-core machine": "A computer system with multiple CPUs or cores.",
    "context switch": "The process of switching from one user process to another, involving traps, scheduler threads, and kernel threads.",
    "thread": "A sequence of execution that consists of data in memory and CPU registers.",
    "struct context": "A structure defined in kernel/proc.h (1951) that includes fields such as s0.",
    "swtch()": "A function that saves the current CPU registers and loads the content of another thread’s context into the CPU registers.",
    "scheduler": "a special thread per CPU responsible for choosing which process to run next.",
    "scheduler thread": "a special thread per CPU that manages process switching.",
    "runnable process": "a process that has p->state = RUNNABLE.",
    "prepare_return": "Saves tp in the trampoline page before returning to user space.",
    "uservec": "Restores the saved tp when entering the kernel from user space.",
    "myproc": "Returns the struct proc pointer for the process running on the current CPU.",
    "round robin": "A scheduling policy that runs each process in turn."
  },
